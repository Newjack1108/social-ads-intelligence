// Social Ads Intelligence - Prisma Schema
// Supports Meta, Google, TikTok (future) with extensible design

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ AUTH & MULTI-TENANCY ============

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   WorkspaceMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token     String? @db.Text
  expires_at       Int?
  token_type       String?
  scope            String?
  id_token         String? @db.Text
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  apiKey    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      WorkspaceMember[]
  dataSources  DataSource[]
  metaRawEvents MetaRawEvent[]
  metaEntities MetaEntity[]
  offlineSales OfflineSale[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        String   // owner, admin, member
  workspaceId String
  userId      String
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ============ DATA SOURCES (extensible for Google/TikTok) ============

model DataSource {
  id          String   @id @default(cuid())
  type        String   // meta, google, tiktok
  externalId  String?
  name        String?
  status      String?
  workspaceId String
  config      Json?    // provider-specific config
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, type, externalId])
}

// ============ META RAW EVENTS (webhook audit) ============

model MetaRawEvent {
  id             String   @id @default(cuid())
  workspaceId    String
  syncId         String?
  receivedAt     DateTime @default(now())
  signatureValid Boolean
  rawPayload     Json
  processingError String?  @db.Text

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, receivedAt])
  @@index([syncId])
}

// ============ META ENTITIES (ad account, campaign, adset, ad) ============

model MetaEntity {
  id              String   @id @default(cuid())
  workspaceId     String
  entityType      String   // account, campaign, adset, ad
  externalId      String
  name            String?
  status          String?
  effectiveStatus String?
  parentId        String?  // FK to parent MetaEntity
  accountId       String?  // top-level account external_id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  parent    MetaEntity?  @relation("EntityHierarchy", fields: [parentId], references: [id])
  children  MetaEntity[] @relation("EntityHierarchy")
  insights  MetaInsightDaily[]
  creatives MetaCreative[] @relation("AdCreatives")
  offlineSales OfflineSale[]

  @@unique([workspaceId, entityType, externalId])
  @@index([workspaceId, accountId])
  @@index([parentId])
}

// ============ META INSIGHTS (daily grain) ============

model MetaInsightDaily {
  id            String   @id @default(cuid())
  entityId      String
  date          DateTime @db.Date
  spend         Decimal  @default(0) @db.Decimal(12, 4)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  frequency     Decimal  @default(0) @db.Decimal(8, 4)
  clicks        Int      @default(0)
  uniqueClicks  Int      @default(0)
  linkClicks    Int      @default(0)
  inlineLinkClicks Int   @default(0)
  outboundClicks Int     @default(0)
  cpc           Decimal  @default(0) @db.Decimal(12, 4)
  cpm           Decimal  @default(0) @db.Decimal(12, 4)
  ctr           Decimal  @default(0) @db.Decimal(8, 4)
  uniqueCtr     Decimal  @default(0) @db.Decimal(8, 4)
  cpp           Decimal  @default(0) @db.Decimal(12, 4)
  videoPlayActions Int   @default(0)
  videoThruplays  Int   @default(0)
  videoP25Watched Int   @default(0)
  videoP50Watched Int   @default(0)
  videoP75Watched Int   @default(0)
  videoP95Watched Int   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  entity    MetaEntity        @relation(fields: [entityId], references: [id], onDelete: Cascade)
  actions   MetaActionDaily[]
  breakdowns MetaBreakdownDaily[]

  @@unique([entityId, date])
  @@index([entityId])
  @@index([date])
}

// ============ META ACTIONS (structured for querying) ============

model MetaActionDaily {
  id              String   @id @default(cuid())
  insightDailyId  String
  actionType      String
  value           Int      @default(0)
  actionValue     Decimal  @default(0) @db.Decimal(12, 4)
  attributionSetting String?

  insightDaily MetaInsightDaily @relation(fields: [insightDailyId], references: [id], onDelete: Cascade)

  @@unique([insightDailyId, actionType])
  @@index([insightDailyId])
  @@index([actionType])
}

// ============ META BREAKDOWNS (age, gender, placement, etc.) ============

model MetaBreakdownDaily {
  id             String   @id @default(cuid())
  insightDailyId String
  breakdownType  String
  breakdownValue String
  metricName     String
  metricValue    Decimal  @db.Decimal(12, 4)

  insightDaily MetaInsightDaily @relation(fields: [insightDailyId], references: [id], onDelete: Cascade)

  @@unique([insightDailyId, breakdownType, breakdownValue, metricName])
  @@index([insightDailyId])
  @@index([breakdownType])
}

// ============ META CREATIVES ============

model MetaCreative {
  id             String   @id @default(cuid())
  adEntityId     String
  creativeId     String?
  primaryText    String?  @db.Text
  headline       String?
  description    String?  @db.Text
  cta            String?
  destinationUrl String?  @db.Text
  imageUrl       String?  @db.Text
  videoUrl       String?  @db.Text
  thumbnailUrl   String?  @db.Text
  lastSeenAt     DateTime @default(now())

  adEntity MetaEntity @relation("AdCreatives", fields: [adEntityId], references: [id], onDelete: Cascade)

  @@unique([adEntityId])
  @@index([adEntityId])
}

// ============ OFFLINE SALES (LeadLock + manual actual sales) ============

model OfflineSale {
  id          String    @id @default(cuid())
  workspaceId String
  entityId    String
  date        DateTime  @db.Date
  amount      Decimal   @db.Decimal(12, 4)
  source      String    // "leadlock" | "manual"
  leadlockId  String?   // LeadLock event/lead id (for dedup)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entity    MetaEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, leadlockId])
  @@index([workspaceId, date])
  @@index([entityId])
}
